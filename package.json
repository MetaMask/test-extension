{
  "name": "@metamask/test-extension",
  "version": "0.0.0",
  "description": "An extension for testing connectivty with the MetaMask extension",
  "homepage": "https://github.com/MetaMask/test-extension#readme",
  "bugs": {
    "url": "https://github.com/MetaMask/test-extension/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaMask/test-extension.git"
  },
  "sideEffects": false,
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "main": "./index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "webpack build",
    "lint": "yarn lint:eslint && yarn lint:constraints && yarn lint:misc --check && yarn lint:dependencies --check && yarn lint:changelog",
    "lint:changelog": "auto-changelog validate --prettier",
    "lint:constraints": "yarn constraints",
    "lint:dependencies": "depcheck && yarn dedupe",
    "lint:eslint": "eslint . --cache",
    "lint:fix": "yarn lint:eslint --fix && yarn lint:constraints --fix && yarn lint:misc --write && yarn lint:dependencies && yarn lint:changelog",
    "lint:misc": "prettier '**/*.json' '**/*.md' '**/*.yml' '!.yarnrc.yml' --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "prepack": "./scripts/prepack.sh"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^3.0.4",
    "@lavamoat/preinstall-always-fail": "^2.0.0",
    "@metamask/auto-changelog": "^5.3.0",
    "@metamask/eslint-config": "^14.0.0",
    "@metamask/eslint-config-browser": "^14.0.0",
    "@metamask/eslint-config-nodejs": "^14.0.0",
    "@metamask/eslint-config-typescript": "^14.0.0",
    "@metamask/providers": "^22.1.0",
    "@types/node": "^18.18",
    "@typescript-eslint/utils": "^8.6.0",
    "@yarnpkg/types": "^4.0.0-rc.52",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^13.0.0",
    "depcheck": "^1.4.3",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import-x": "^4.3.0",
    "eslint-plugin-jsdoc": "^50.2.4",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-packagejson": "^2.5.8",
    "process": "^0.11.10",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.6.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  },
  "packageManager": "yarn@4.1.1",
  "engines": {
    "node": "^18.20 || ^20.17 || >=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false,
      "vite>esbuild": false
    }
  }
}
